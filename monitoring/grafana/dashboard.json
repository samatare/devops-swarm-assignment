{
  "dashboard": {
    "title": "Docker Swarm Overview",
    "uid": "swarm-overview",
    "panels": [
      {
        "title": "Service Replica Count",
        "type": "stat",
        "targets": [{"expr": "count by (container_label_com_docker_swarm_service_name)(container_tasks_state{state=\"running\"})"}],
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0}
      },
      {
        "title": "Service Health Status",
        "type": "table",
        "targets": [{"expr": "up{job=~\".*\"}"}],
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0}
      },
      {
        "title": "Node CPU Usage %",
        "type": "timeseries",
        "targets": [{"expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)"}],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6}
      },
      {
        "title": "Node Memory Usage %",
        "type": "timeseries",
        "targets": [{"expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100"}],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6}
      },
      {
        "title": "Node Disk Usage %",
        "type": "gauge",
        "targets": [{"expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100"}],
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0}
      },
      {
        "title": "Container Restart Count (last 1h)",
        "type": "timeseries",
        "targets": [{"expr": "increase(container_restart_count[1h])"}],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14}
      },
      {
        "title": "Network RX Bytes/s per Service",
        "type": "timeseries",
        "targets": [{"expr": "sum by (name)(rate(container_network_receive_bytes_total[5m]))"}],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14}
      },
      {
        "title": "Container Memory Usage",
        "type": "timeseries",
        "targets": [{"expr": "container_memory_usage_bytes{name=~\"app_.*\"}"}],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 22}
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "10s"
  }
}
